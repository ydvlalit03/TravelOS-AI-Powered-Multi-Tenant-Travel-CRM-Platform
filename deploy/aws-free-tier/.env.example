# Copy to .env (in this folder) and fill the two secrets. Everything else runs
# keyless with built-in mocks — no API keys needed for the demo.
#
# Generate the secrets:
#   SECRET_KEY:                  openssl rand -hex 32
#   CREDENTIALS_ENCRYPTION_KEY:  python3 -c "from cryptography.fernet import Fernet;print(Fernet.generate_key().decode())"
#   (no python on the box? use: openssl rand -base64 32 | tr '+/' '-_' )

ENVIRONMENT=production
SECRET_KEY=REPLACE_ME
CREDENTIALS_ENCRYPTION_KEY=REPLACE_ME

POSTGRES_USER=travelos
POSTGRES_PASSWORD=travelos
POSTGRES_DB=travelos

# Keep mocks on (free, no keys). To use real AI later, set a free Gemini key:
# GEMINI_API_KEY=...
# LLM_TEXT_PROVIDER=gemini
# LLM_IMAGE_PROVIDER=gemini
