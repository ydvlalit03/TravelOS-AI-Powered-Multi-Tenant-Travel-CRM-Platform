# ─────────── TravelOS environment ───────────
# Copy to .env and fill in. Never commit .env.

# --- Core ---
ENVIRONMENT=development
SECRET_KEY=change-me-to-a-long-random-string
# Used to encrypt per-tenant integration credentials at rest (Fernet key, 32 url-safe base64 bytes)
CREDENTIALS_ENCRYPTION_KEY=

# --- Database ---
POSTGRES_USER=travelos
POSTGRES_PASSWORD=travelos
POSTGRES_DB=travelos
POSTGRES_HOST=db
POSTGRES_PORT=5432
# App connects as the dedicated non-superuser role so Postgres RLS is enforced
# (the role + pgvector extension are created by infra/db/init.sql on first init).
DATABASE_URL=postgresql+asyncpg://travelos_app:travelos_app@db:5432/travelos

# --- Redis (jobs / cache / scheduler) ---
REDIS_URL=redis://redis:6379/0

# --- Auth ---
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# --- LLM providers (free-tier first) ---
# Primary text model. Get a free key at https://aistudio.google.com/apikey
GEMINI_API_KEY=
GEMINI_TEXT_MODEL=gemini-2.5-flash
GEMINI_IMAGE_MODEL=gemini-2.5-flash-image
# Fast CRM replies. Free key: https://console.groq.com
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile
# Default text/image provider. With no key set, text falls back to a built-in
# mock so the app runs offline. Set GEMINI_API_KEY for real output.
LLM_TEXT_PROVIDER=gemini
# Image provider: mock (keyless, default) | gemini (needs key) | pollinations
LLM_IMAGE_PROVIDER=mock

# --- Email (Phase 2). Resend free 3k/mo OR Brevo 300/day ---
EMAIL_PROVIDER=console          # console | resend | brevo
RESEND_API_KEY=
BREVO_API_KEY=
EMAIL_FROM=hello@travelos.local

# --- SMS (Phase 2). India: MSG91 / Fast2SMS ---
SMS_PROVIDER=console            # console | msg91 | fast2sms
MSG91_API_KEY=
FAST2SMS_API_KEY=

# --- WhatsApp Cloud API (Phase 4) ---
WHATSAPP_PROVIDER=console       # console | cloud
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_TOKEN=
WHATSAPP_VERIFY_TOKEN=travelos-wa-verify

# --- Background scheduler ---
# true in single-process dev. In multi-worker prod set false on web and run the
# dedicated worker (python -m app.workers.run).
RUN_SCHEDULER=true

# --- Meta (Instagram publish + Lead Ads webhook). Phase 2/3 ---
META_APP_ID=
META_APP_SECRET=
META_WEBHOOK_VERIFY_TOKEN=travelos-verify

# --- Storage ---
STORAGE_BACKEND=local           # local | s3
S3_BUCKET=
AWS_REGION=ap-south-1
# Public base URL for assets (e.g. a CloudFront domain). Required for real IG
# publishing — the Graph API fetches the poster image by public URL.
ASSET_PUBLIC_BASE_URL=

# --- Frontend ---
VITE_API_BASE_URL=http://localhost:8000

# --- Host port mappings (override if these ports are taken by other projects) ---
# Redis is intentionally NOT published to the host.
DB_HOST_PORT=5432
BACKEND_HOST_PORT=8000
FRONTEND_HOST_PORT=5173
